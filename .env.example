# Copy to .env and fill in real values. Do NOT commit .env.

PORT=3000
NODE_ENV=production

# MongoDB connection string (e.g. MongoDB Atlas SRV URI)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/quran-academy

# JWT secrets — use long random strings
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=30d

# Comma-separated allowed origins, or * for all
CORS_ORIGINS=*

# --- Email (SMTP) ---
# Leave MAIL_USER / MAIL_PASSWORD blank to log OTP codes to console instead of emailing.
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=no-reply@your-domain.com
MAIL_PASSWORD=your-mailbox-password
MAIL_FROM=Quran Academy <no-reply@your-domain.com>
